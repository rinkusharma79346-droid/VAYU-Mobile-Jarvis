<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="260dp"
    android:layout_height="72dp"
    android:background="@drawable/bg_hud"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top row: step counter + stop button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvHudStep"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Step 1/50"
                android:textColor="#FF00E5FF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/btnHudStop"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:background="@drawable/bg_kill_switch"
                android:text="STOP"
                android:textColor="#FFFFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

        </LinearLayout>

        <!-- Action description -->
        <TextView
            android:id="@+id/tvHudAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="TAP (540, 960)"
            android:textColor="#B3FFFFFF"
            android:textSize="10sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/pbHudProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="6dp"
            android:max="50"
            android:progress="0"
            android:progressDrawable="@drawable/bg_progress_bar" />

    </LinearLayout>
</FrameLayout>
